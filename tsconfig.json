{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": [
      "esnext"
    ],
    "types": [
      "@cloudflare/workers-types"
    ],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist"
  },
  "include": [
    "src/**/*",
    "src/.old/invoicexpress.ts",
    "src/.old/storage.ts",
    "src/.old/nif.ts",
    "src/.old/shopify.ts",
    "src/.old/vat.ts"
  ]
}
