{
  "name": "shopify-invoicexpress-worker",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev -c wrangler.jsonc",
    "deploy": "wrangler deploy",
    "deploy:safe": "node scripts/pre-deploy-backup.mjs && wrangler deploy",
    "backup": "node scripts/pre-deploy-backup.mjs",
    "gen:builder": "esbuild src/ix/builder.ts --bundle --format=esm --platform=node --outfile=scripts/.gen/builder.mjs",
    "gen:normalize": "esbuild src/ix/normalize-local.ts --bundle --format=esm --platform=node --outfile=scripts/.gen/normalize-local.mjs",
    "audit:shopify": "npm run gen:builder && node scripts/audit-shopify.mjs",
    "shadow:normalize": "npm run gen:builder && npm run gen:normalize && node scripts/shadow-normalize.mjs",
    "shadow:refund": "npm run gen:builder && npm run gen:normalize && node scripts/shadow-refund.mjs",
    "build": "wrangler deploy --dry-run -c wrangler.jsonc",
    "preview": "wrangler dev -c wrangler.jsonc"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240101.0",
    "@hey-api/openapi-ts": "^0.94.1",
    "typescript": "^5.0.0",
    "wrangler": "^4.69.0"
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "hono": "^4.12.7",
    "p-retry": "^7.1.1",
    "resend": "^6.12.3"
  }
}
